{
  "imports": {
    "@actions/core": "npm:@actions/core@1.11.1",
    "@octokit/graphql": "npm:@octokit/graphql@9.0.3",
    "@std/assert": "jsr:@std/assert@1"
  },
  "tasks": {
    "build:action": "deno bundle --minify action-src/main.ts -o dist/main.mjs",
    "fix": "deno fmt && deno lint && deno check",
    "sync": "deno run -R=./state.json,./starred-releases.atom,./starred-releases.html -W=./state.json,./starred-releases.atom,./starred-releases.html cli.ts",
    "test": "deno test -RWNE"
  },
  "exclude": ["dist/", "tmp/"]
}
